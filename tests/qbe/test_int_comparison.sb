fn main() {
    if 1 < 2 == false {
        println("FAIL: 1 < 2 should be true")
        exit(1)
    }
    if 2 < 1 == true {
        println("FAIL: 2 < 1 should be false")
        exit(1)
    }
    if 1 < 1 == true {
        println("FAIL: 1 < 1 should be false")
        exit(1)
    }

    if 1 <= 2 == false {
        println("FAIL: 1 <= 2 should be true")
        exit(1)
    }
    if 2 <= 1 == true {
        println("FAIL: 2 <= 1 should be false")
        exit(1)
    }
    if 1 <= 1 == false {
        println("FAIL: 1 <= 1 should be true")
        exit(1)
    }

    if 2 > 1 == false {
        println("FAIL: 2 > 1 should be true")
        exit(1)
    }
    if 1 > 2 == true {
        println("FAIL: 1 > 2 should be false")
        exit(1)
    }
    if 1 > 1 == true {
        println("FAIL: 1 > 1 should be false")
        exit(1)
    }

    if 2 >= 1 == false {
        println("FAIL: 2 >= 1 should be true")
        exit(1)
    }
    if 1 >= 2 == true {
        println("FAIL: 1 >= 2 should be false")
        exit(1)
    }
    if 1 >= 1 == false {
        println("FAIL: 1 >= 1 should be true")
        exit(1)
    }

    if 5 == 5 == false {
        println("FAIL: 5 == 5 should be true")
        exit(1)
    }
    if 5 == 6 == true {
        println("FAIL: 5 == 6 should be false")
        exit(1)
    }

    if 5 != 6 == false {
        println("FAIL: 5 != 6 should be true")
        exit(1)
    }
    if 5 != 5 == true {
        println("FAIL: 5 != 5 should be false")
        exit(1)
    }

    println("PASS")
    exit(0)
}
