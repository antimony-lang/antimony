fn main() {
    let reached = 0

    if true {
        reached = 1
    }
    if reached != 1 {
        println("FAIL: if true body should execute")
        exit(1)
    }

    if false {
        reached = 99
    }
    if reached != 1 {
        println("FAIL: if false body should not execute")
        exit(1)
    }

    let branch = 0
    if true {
        branch = 1
    } else {
        branch = 2
    }
    if branch != 1 {
        println("FAIL: if/else true branch should be taken")
        exit(1)
    }

    if false {
        branch = 1
    } else {
        branch = 2
    }
    if branch != 2 {
        println("FAIL: if/else false branch should be taken")
        exit(1)
    }

    let val = 5
    let result = 0
    if val < 3 {
        result = 1
    } else {
        if val < 7 {
            result = 2
        } else {
            result = 3
        }
    }
    if result != 2 {
        println("FAIL: nested if/else should produce 2")
        exit(1)
    }

    println("PASS")
    exit(0)
}
