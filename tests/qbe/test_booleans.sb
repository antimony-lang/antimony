fn main() {
    let t = true
    let f = false

    if t == false {
        println("FAIL: t should be true")
        exit(1)
    }
    if f == true {
        println("FAIL: f should be false")
        exit(1)
    }

    if true && true == false {
        println("FAIL: true && true should be true")
        exit(1)
    }
    if true && false == true {
        println("FAIL: true && false should be false")
        exit(1)
    }
    if false && false == true {
        println("FAIL: false && false should be false")
        exit(1)
    }

    if true || false == false {
        println("FAIL: true || false should be true")
        exit(1)
    }
    if false || false == true {
        println("FAIL: false || false should be false")
        exit(1)
    }

    if (true && true) || false == false {
        println("FAIL: (true && true) || false should be true")
        exit(1)
    }

    println("PASS")
    exit(0)
}
