fn main() {
    let x = 10

    x += 5
    if x != 15 {
        println("FAIL: 10 += 5 should be 15")
        exit(1)
    }

    x -= 3
    if x != 12 {
        println("FAIL: 15 -= 3 should be 12")
        exit(1)
    }

    x *= 2
    if x != 24 {
        println("FAIL: 12 *= 2 should be 24")
        exit(1)
    }

    x /= 4
    if x != 6 {
        println("FAIL: 24 /= 4 should be 6")
        exit(1)
    }

    println("PASS")
    exit(0)
}
