fn stdlib_string_main() {
    log_test_stage("Testing stdlib/string")
    test_string_str_len()
    test_string_repeat()
    test_string_to_int()
}

fn test_string_str_len() {
    assert(str_len("hello") == 5)
    assert(str_len("") == 0)
    assert(str_len("ab") == 2)
}

fn test_string_repeat() {
    assert(repeat("ab", 3) == "ababab")
    assert(repeat("x", 1) == "x")
    assert(repeat("hi", 0) == "")
}

fn test_string_to_int() {
    assert(to_int("42") == 42)
    assert(to_int("0") == 0)
    assert(to_int("100") == 100)
}
